# The repo's own gitignore (not the global one - that lives at config/git/ignore)

# Backup directory created by install.sh on first run (in case the repo itself
# lives at ~ and the backup dir lands inside it - belt-and-suspenders).
.dotfiles-backup/

# Anything ending in .local - convention for machine-specific overrides
*.local

# Machine-specific zsh overrides, sourced by the *.zsh glob in config/zsh/.zshrc.
# Live alongside the tracked aliases.zsh / functions.zsh / etc. so they get picked
# up automatically - this is where secrets and per-host tweaks go.
home/.config/zsh/local.zsh
home/.config/zsh/work.zsh

# Antidote/zsh runtime cruft - generated, never committed.
home/.config/zsh/.zcompdump*
home/.config/zsh/.zsh_history
home/.config/zsh/.zsh_plugins.zsh

# Common noise
.DS_Store
*.swp

# Claude Code per-project settings - auto-created when permissions are approved
# in this directory. Local-only, never meant to ship.
.claude/

# machine-local + runtime (path-independent, robust to layout changes)
local.zsh
work.zsh
.zsh_history
.zcompdump*
.zsh_plugins.zsh
