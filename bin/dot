#!/usr/bin/env bash
#
# dot - a cross-platform package + dotfiles manager.
#
#   Bootstrap a machine, manage the package manifest, and symlink configs
#   (via GNU Stow). Package lists live in bin/packages/*.txt; install logic in
#   bin/lib/bootstrap.sh.
#
# Commands:
#   init                 full bootstrap: install packages, link configs, set up shell
#   add <pkg>            install <pkg> and add it to the manifest
#   remove <pkg>         uninstall <pkg> and drop it from the manifest
#   update               upgrade packages + git pull + relink
#   list                 show the package manifest with install status
#   link [-f|--force]    stow home/ into $HOME
#   unlink               remove our symlinks
#   backup               tar files stow would conflict with into ~/.dotfiles-backup/
#   clean                remove broken symlinks pointing into $DOTFILES
#   doctor               health check
#   help                 show this help

set -Eeuo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || python3 -c 'import os,sys;print(os.path.realpath(sys.argv[1]))' "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
: "${DOTFILES:=$(cd "$SCRIPT_DIR/.." && pwd)}"
export DOTFILES
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"

# shellcheck source=lib/packages.sh
source "$SCRIPT_DIR/lib/packages.sh"
# shellcheck source=lib/bootstrap.sh   (provides logging, spin, detect_os, installers, ...)
source "$SCRIPT_DIR/lib/bootstrap.sh"

PKG="home"   # the Stow package: $DOTFILES/home/ mirrors $HOME

require_stow() {
  command -v stow >/dev/null 2>&1 && return 0
  err "GNU Stow is not installed."
  [[ "$OSTYPE" == darwin* ]] && err "  brew install stow" || err "  sudo apt-get install stow"
  exit 1
}

usage() {
  cat <<EOF

  dot <command> [args]    cross-platform package + dotfiles manager
                          (repo: ${DOTFILES/#$HOME/~})

  Setup
    init                  full bootstrap: packages + link + antidote + shell
    add <pkg>             install <pkg> and add it to the manifest
    remove <pkg>          uninstall <pkg> and drop it from the manifest
    update                upgrade packages + git pull + relink
    list                  show the package manifest with install status

  Symlinks (GNU Stow)
    link [-f|--force]     stow home/ into \$HOME (re-runnable; --force replaces conflicts)
    unlink                remove our symlinks
    backup                tar conflicting files into ~/.dotfiles-backup/
    clean                 remove broken symlinks pointing into \$DOTFILES

  Maintenance
    doctor                health check
    help                  this help

EOF
}

# ----------------------------------------------------------------------------- Stow
conflicts() {
  stow -n -v -d "$DOTFILES" -t "$HOME" "$PKG" 2>&1 \
    | sed -n 's/.*existing target is not owned by stow: //p'
}

cmd_backup() {
  require_stow
  local list; list="$(conflicts || true)"
  [[ -z "$list" ]] && { ok "Nothing to back up."; return; }
  local dir="$HOME/.dotfiles-backup"; mkdir -p "$dir"
  local archive="$dir/dotfiles_backup_$(date +%Y%m%d-%H%M%S).tar.gz"
  ( cd "$HOME" && tar -czf "$archive" $list )
  ok "Backed up conflicts -> ${archive/#$HOME/~}"
}

cmd_link() {
  require_stow
  local force=0
  [[ "${1:-}" == "-f" || "${1:-}" == "--force" ]] && force=1
  if [[ "$force" == 1 ]]; then
    local list; list="$(conflicts || true)"
    if [[ -n "$list" ]]; then
      cmd_backup
      local p
      while IFS= read -r p; do [[ -n "$p" ]] && rm -rf "${HOME:?}/$p" && warn "replaced $p"; done <<< "$list"
    fi
  fi
  info "Stowing home/ into \$HOME"
  stow -R -v -d "$DOTFILES" -t "$HOME" "$PKG"
  ok "Linked."
}

cmd_unlink() { require_stow; info "Unstowing home/"; stow -D -v -d "$DOTFILES" -t "$HOME" "$PKG"; ok "Unlinked."; }

cmd_clean() {
  local removed=0 root link target
  for root in "$HOME" "$XDG_CONFIG_HOME"; do
    [[ -d "$root" ]] || continue
    while IFS= read -r -d '' link; do
      target="$(readlink "$link" || true)"
      if [[ ( "$target" == *"/.dotfiles/"* || "$target" == "$DOTFILES"* ) && ! -e "$link" ]]; then
        rm "$link"; ok "removed broken symlink ${link/#$HOME/~}"; removed=$((removed + 1))
      fi
    done < <(find "$root" -maxdepth 1 -type l -print0 2>/dev/null)
  done
  [[ "$removed" == 0 ]] && ok "No broken symlinks found."
}

# ----------------------------------------------------------------------------- Packages
# Map a manifest package name to the binary that proves it's installed.
pkg_bin_name() {
  case "$1" in
    ripgrep)                  echo rg ;;
    bat)                      [[ "$OS" == macos ]] && echo bat || echo batcat ;;
    fd|fd-find)               [[ "$OS" == macos ]] && echo fd || echo fdfind ;;
    visual-studio-code|vscode) echo code ;;
    *)                        echo "$1" ;;
  esac
}

pkg_is_installed() {
  local p="$1"
  [[ "$p" == nvm ]] && { [[ -d "$HOME/.nvm" ]]; return; }
  command -v "$(pkg_bin_name "$p")" >/dev/null 2>&1
}

cmd_list() {
  detect_os
  local groups
  if [[ "$OS" == "macos" ]]; then groups=("brew:BREW_PKGS" "cask:BREW_CASKS")
  else groups=("apt:APT_PKGS" "curl:CURL_PKGS"); fi
  local g name arr p
  for g in "${groups[@]}"; do
    name="${g%%:*}"; arr="${g#*:}"
    printf "\n%s%s%s\n" "$C_B" "$name" "$C_R"
    eval "local items=( \"\${$arr[@]}\" )"
    for p in "${items[@]}"; do
      if pkg_is_installed "$p"; then printf "  %s\xe2\x9c\x93%s %s\n" "$C_G" "$C_R" "$p"
      else printf "  %s\xe2\x80\x93%s %s\n" "$C_Y" "$C_R" "$p"; fi
    done
  done
  echo
}

cmd_add() {
  local pkg="${1:-}"; [[ -z "$pkg" ]] && { err "usage: dot add <pkg>"; exit 1; }
  detect_os
  local mf
  if declare -F "install_$pkg" >/dev/null 2>&1; then
    "install_$pkg"                 # tool has a custom installer (curl/script)
    mf="$PKG_DIR/curl.txt"
  else
    pkg_install_one "$pkg"         # OS package manager
    mf="$(manifest_file_for_os)"
  fi
  if grep -qxF "$pkg" "$mf" 2>/dev/null; then ok "$pkg already in $(basename "$mf")"
  else printf '%s\n' "$pkg" >> "$mf"; ok "added $pkg -> $(basename "$mf")"; fi
}

cmd_remove() {
  local pkg="${1:-}"; [[ -z "$pkg" ]] && { err "usage: dot remove <pkg>"; exit 1; }
  detect_os
  # Custom-installer tools (curl.txt) can't be auto-uninstalled - just untrack.
  if grep -qxF "$pkg" "$PKG_DIR/curl.txt" 2>/dev/null; then
    grep -vxF "$pkg" "$PKG_DIR/curl.txt" > "$PKG_DIR/curl.txt.tmp" && mv "$PKG_DIR/curl.txt.tmp" "$PKG_DIR/curl.txt"
    warn "$pkg removed from manifest; uninstall the binary yourself (custom installer)."
    return
  fi
  pkg_remove_one "$pkg"
  local mf; mf="$(manifest_file_for_os)"
  if grep -qxF "$pkg" "$mf" 2>/dev/null; then
    grep -vxF "$pkg" "$mf" > "$mf.tmp" && mv "$mf.tmp" "$mf"; ok "removed $pkg from $(basename "$mf")"
  else ok "$pkg was not in $(basename "$mf")"; fi
}

cmd_update() {
  detect_os
  update_packages
  info "git pull"; git -C "$DOTFILES" pull --ff-only 2>/dev/null || warn "git pull skipped (dirty or no upstream)"
  cmd_link
}

# ----------------------------------------------------------------------------- init / doctor
cmd_init() {
  info "Bootstrapping dotfiles from $DOTFILES"
  check_prereqs
  detect_os
  info "Detected OS: $OS"
  install_prereqs
  chmod +x "$DOTFILES/bin/"* 2>/dev/null || true
  info "Snapshotting shell rc files (safety net)..."; snapshot_shell_configs
  info "Linking config (replacing any non-symlink originals)..."; cmd_link --force
  install_antidote
  setup_local_files
  setup_vscode
  install_fonts
  install_wezterm_windows_stub
  set_default_shell
  echo
  ok "Done. Open a new shell to pick up the changes."
  echo "    Backups (if any): ~/.dotfiles-backup/"
  echo "    Day-to-day: dot list, dot add <pkg>, dot update, dot doctor"
}

cmd_doctor() {
  detect_os
  info "doctor - OS: $OS, DOTFILES: ${DOTFILES/#$HOME/~}"

  local t
  for t in git curl stow zsh; do
    command -v "$t" >/dev/null 2>&1 && ok "$t present" || warn "$t MISSING"
  done

  # Symlinks: derived from the stow tree - every tracked file under home/ must
  # resolve to its repo copy at the matching $HOME path (covers anything you add,
  # e.g. ~/.pi later, with no hardcoding). `-ef` is portable (no readlink -f).
  local f rel linked=0 broken=()
  while IFS= read -r -d '' f; do
    rel="${f#$DOTFILES/home/}"
    if [[ "$HOME/$rel" -ef "$f" ]]; then linked=$((linked + 1)); else broken+=("~/$rel"); fi
  done < <(find "$DOTFILES/home" -type f -print0)
  if [[ ${#broken[@]} -eq 0 ]]; then ok "all $linked tracked files linked into \$HOME"
  else warn "${#broken[@]} tracked file(s) NOT linked:"; printf '    %s\n' "${broken[@]}"; fi

  # Stow conflicts / broken links
  local c; c="$(conflicts || true)"
  [[ -z "$c" ]] && ok "stow: no conflicts" || { warn "stow conflicts:"; printf '    %s\n' $c; }

  # Missing packages
  local groups arr p missing=()
  if [[ "$OS" == "macos" ]]; then groups=(BREW_PKGS BREW_CASKS); else groups=(APT_PKGS CURL_PKGS); fi
  for arr in "${groups[@]}"; do
    eval "local items=( \"\${$arr[@]}\" )"
    for p in "${items[@]}"; do pkg_is_installed "$p" || missing+=("$p"); done
  done
  [[ ${#missing[@]} -eq 0 ]] && ok "all manifest packages installed" \
    || warn "missing packages: ${missing[*]}  (run: dot init  or  dot add <pkg>)"
}

# ----------------------------------------------------------------------------- dispatch
main() {
  local cmd="${1:-help}"; shift || true
  case "$cmd" in
    init)            cmd_init ;;
    add)             cmd_add "${1:-}" ;;
    remove|rm)       cmd_remove "${1:-}" ;;
    update|upgrade)  cmd_update ;;
    list|ls)         cmd_list ;;
    link)            cmd_link "$@" ;;
    unlink)          cmd_unlink ;;
    backup)          cmd_backup ;;
    clean)           cmd_clean ;;
    doctor)          cmd_doctor ;;
    help|-h|--help)  usage ;;
    *) err "Unknown command: $cmd"; usage; exit 1 ;;
  esac
}

main "$@"
