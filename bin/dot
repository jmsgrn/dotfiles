#!/usr/bin/env bash
#
# dot - manage this dotfiles repo's symlinks and backups.
#
# Conventions:
#   $DOTFILES/config/<pkg>/   →  $XDG_CONFIG_HOME/<pkg>     (whole-dir symlink)
#   $DOTFILES/home/<file>     →  $HOME/<file>               (per-file symlink)
#
# Subcommands:
#   help                 show this help
#   link    [-f] [pkg]   create symlinks; -f/--force removes existing files first
#   unlink  [pkg|all]    remove our symlinks (default: all)
#   backup               tar up the files we would replace, into ~/.dotfiles-backup/
#   clean                remove broken symlinks pointing into $DOTFILES

set -Eeuo pipefail

# -----------------------------------------------------------------------------
# Bootstrap: locate the repo and source shared helpers.
# -----------------------------------------------------------------------------
# Resolve where this script lives, even if invoked via a symlink on PATH.
SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || python3 -c 'import os,sys;print(os.path.realpath(sys.argv[1]))' "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"

# $DOTFILES = parent of bin/. Respect a pre-set value if the user has one.
: "${DOTFILES:=$(cd "$SCRIPT_DIR/.." && pwd)}"
export DOTFILES

XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"

# shellcheck source=lib/common.sh
source "$SCRIPT_DIR/lib/common.sh"

# -----------------------------------------------------------------------------
# Usage
# -----------------------------------------------------------------------------
usage() {
  cat <<EOF

  $(fmt_cmd dot) $(printf "%s" "${DIM}<command> [args]${RESET}")

  Manage symlinks for the dotfiles repo at $(fmt_path "$(home_tilde "$DOTFILES")").

  ${BOLD}Commands${RESET}
    $(fmt_cmd help)                       show this help
    $(fmt_cmd link)    ${DIM}[-f|--force] [pkg]${RESET}   link config/ and home/ (force replaces existing)
    $(fmt_cmd unlink)  ${DIM}[pkg|all]${RESET}            remove our symlinks
    $(fmt_cmd backup)                     tar files we'd replace into ~/.dotfiles-backup/
    $(fmt_cmd clean)                      remove broken symlinks pointing into \$DOTFILES

  ${BOLD}Layout${RESET}
    \$DOTFILES/config/<pkg>/ → \$XDG_CONFIG_HOME/<pkg>
    \$DOTFILES/home/<file>   → \$HOME/<file>

EOF
}

# Packages under config/ that `dot` does NOT manage - their destinations are
# OS-specific or non-XDG, so install.sh handles them with its own glue.
SKIP_PKGS=(vscode)

is_skipped() {
  local name="$1" skip
  for skip in "${SKIP_PKGS[@]}"; do
    [[ "$name" == "$skip" ]] && return 0
  done
  return 1
}

# -----------------------------------------------------------------------------
# Enumerate what we manage.
#
# Emits one "<src>\t<dest>\t<label>" line per linkable entry on stdout.
# Filtered by $1 (pkg name) if provided and not "all".
# -----------------------------------------------------------------------------
enumerate() {
  local filter="${1:-all}"

  # config/<pkg>/ → $XDG_CONFIG_HOME/<pkg>
  if [[ -d "$DOTFILES/config" ]]; then
    local d name
    for d in "$DOTFILES/config"/*/; do
      [[ -d "$d" ]] || continue
      name="$(basename "$d")"
      # Skip packages with non-XDG destinations (handled by install.sh).
      # When the user explicitly names one, still skip - but make it visible.
      if is_skipped "$name"; then
        if [[ "$filter" == "$name" ]]; then
          log_warn "$name: handled by install.sh (non-XDG destination) - skipping"
        fi
        continue
      fi
      if [[ "$filter" == "all" || "$filter" == "$name" ]]; then
        printf "%s\t%s\t%s\n" "${d%/}" "$XDG_CONFIG_HOME/$name" "$name"
      fi
    done
  fi

  # home/<file> → $HOME/<file>  (dotfiles included)
  if [[ -d "$DOTFILES/home" ]]; then
    local entry name
    shopt -s dotglob nullglob
    for entry in "$DOTFILES/home"/*; do
      name="$(basename "$entry")"
      [[ "$name" == "." || "$name" == ".." || "$name" == ".DS_Store" ]] && continue
      if [[ "$filter" == "all" || "$filter" == "$name" || "$filter" == "${name#.}" ]]; then
        printf "%s\t%s\t%s\n" "$entry" "$HOME/$name" "$name"
      fi
    done
    shopt -u dotglob nullglob
  fi
}

# -----------------------------------------------------------------------------
# link / unlink
# -----------------------------------------------------------------------------
do_link() {
  local src="$1" dest="$2" label="$3" force="${4:-0}"
  local display; display="$(home_tilde "$dest")"

  if [[ -L "$dest" && "$(readlink "$dest")" == "$src" ]]; then
    printf "  %s%s%s %-22s %s→ %s%s\n" "$DIM" "·" "$RESET" "$label" "$DIM" "$display already linked" "$RESET"
    return
  fi
  if [[ -e "$dest" || -L "$dest" ]]; then
    if [[ "$force" == "1" ]]; then
      # Use rm -rf because $dest may be a directory we're replacing with a
      # symlink (e.g. a real ~/.config/zsh directory being replaced by a link
      # to $DOTFILES/config/zsh). Caller is expected to have backed up first.
      rm -rf "$dest"
      printf "  %s!%s %-22s %s(removed existing)%s\n" "$YELLOW" "$RESET" "$label" "$DIM" "$RESET"
    else
      log_warn "$label: $display exists - skipping (run 'dot backup && dot link --force' to replace)"
      return
    fi
  fi
  mkdir -p "$(dirname "$dest")"
  ln -s "$src" "$dest"
  printf "  %s+%s %-22s %s→ %s%s\n" "$GREEN" "$RESET" "$label" "$DIM" "$display" "$RESET"
}

do_unlink() {
  local src="$1" dest="$2" label="$3"
  local display; display="$(home_tilde "$dest")"

  if [[ -L "$dest" && "$(readlink "$dest")" == "$src" ]]; then
    rm "$dest"
    printf "  %s-%s %-22s %s%s%s\n" "$RED" "$RESET" "$label" "$DIM" "$display" "$RESET"
  elif [[ -L "$dest" ]]; then
    log_warn "$label: $display is a symlink but not ours - skipping"
  elif [[ -e "$dest" ]]; then
    log_warn "$label: $display exists but is not our symlink - skipping"
  fi
}

cmd_link() {
  local force=0 pkg="all"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -f|--force) force=1; shift ;;
      -*)         log_error "Unknown option: $1"; return 1 ;;
      *)          pkg="$1"; shift ;;
    esac
  done

  local title_suffix=""
  [[ "$pkg" != "all" ]] && title_suffix=" ${DIM}─ ${pkg}${RESET}"
  [[ "$force" == "1" ]] && title_suffix+=" ${DIM}(--force)${RESET}"
  fmt_title "dot link${title_suffix}"

  local any=0
  while IFS=$'\t' read -r src dest label; do
    do_link "$src" "$dest" "$label" "$force"
    any=1
  done < <(enumerate "$pkg")
  if [[ "$any" == 0 ]]; then
    log_error "No matching packages for '$pkg'"
    return 1
  fi
  echo
}

cmd_unlink() {
  local pkg="${1:-all}"
  fmt_title "dot unlink${pkg:+ ${DIM}─ ${pkg}${RESET}}"
  local any=0
  while IFS=$'\t' read -r src dest label; do
    do_unlink "$src" "$dest" "$label"
    any=1
  done < <(enumerate "$pkg")
  if [[ "$any" == 0 ]]; then
    log_error "No matching packages for '$pkg'"
    return 1
  fi
  echo
}

# -----------------------------------------------------------------------------
# backup - tar everything we'd overwrite into ~/.dotfiles-backup/<timestamp>.tar.gz
# -----------------------------------------------------------------------------
cmd_backup() {
  local backup_dir="$HOME/.dotfiles-backup"
  local ts; ts="$(date +%Y%m%d-%H%M%S)"
  local archive="$backup_dir/dotfiles_backup_$ts.tar.gz"

  mkdir -p "$backup_dir"

  fmt_title "dot backup"

  local tmpfile; tmpfile="$(mktemp)"

  # Collect destinations that currently exist as real files (not our symlinks)
  while IFS=$'\t' read -r src dest label; do
    if [[ -L "$dest" && "$(readlink "$dest")" == "$src" ]]; then
      continue  # already our symlink - nothing to back up
    elif [[ -e "$dest" || -L "$dest" ]]; then
      # Store path relative to $HOME so tar -C $HOME extracts cleanly later
      printf "%s\n" "${dest#$HOME/}" >>"$tmpfile"
      log_info "would back up $(home_tilde "$dest")"
    fi
  done < <(enumerate "all")

  if [[ ! -s "$tmpfile" ]]; then
    rm -f "$tmpfile"
    log_ok "Nothing to back up."
    echo
    return
  fi

  tar -czf "$archive" -C "$HOME" -T "$tmpfile"
  rm -f "$tmpfile"
  log_ok "Backup written: $(fmt_path "$(home_tilde "$archive")")"
  echo
}

# -----------------------------------------------------------------------------
# clean - remove broken symlinks that point inside $DOTFILES
# -----------------------------------------------------------------------------
cmd_clean() {
  fmt_title "dot clean"
  local removed=0

  # Scan $HOME top-level and $XDG_CONFIG_HOME for broken symlinks pointing into $DOTFILES
  local roots=("$HOME" "$XDG_CONFIG_HOME")
  local root link target
  for root in "${roots[@]}"; do
    [[ -d "$root" ]] || continue
    # -maxdepth 1 keeps it cheap and avoids walking into project dirs
    while IFS= read -r -d '' link; do
      target="$(readlink "$link" || true)"
      if [[ "$target" == "$DOTFILES"* && ! -e "$link" ]]; then
        rm "$link"
        log_ok "removed broken symlink $(home_tilde "$link")"
        removed=$((removed + 1))
      fi
    done < <(find "$root" -maxdepth 1 -type l -print0 2>/dev/null)
  done

  if [[ "$removed" == 0 ]]; then
    log_ok "No broken symlinks found."
  fi
  echo
}

# -----------------------------------------------------------------------------
# Dispatch
# -----------------------------------------------------------------------------
main() {
  local cmd="${1:-help}"; shift || true
  case "$cmd" in
    help|-h|--help) usage ;;
    link)           cmd_link   "$@" ;;
    unlink)         cmd_unlink "${1:-all}" ;;
    backup)         cmd_backup ;;
    clean)          cmd_clean ;;
    *)
      log_error "Unknown command: $cmd"
      usage
      exit 1
      ;;
  esac
}

main "$@"
