#!/usr/bin/env bash
# tmux-sessionizer - Primeagen-style fuzzy session switcher
# Bind to a global key (e.g. Ctrl-f) in zsh:  bindkey -s ^f "tmux-sessionizer\n"
# Or call directly with a path arg

if [[ $# -eq 1 ]]; then
  selected=$1
else
  # Search common project locations - tune to taste
  selected=$(find \
    ~/projects \
    "${DOTFILES:-$HOME/projects/dotfiles}" \
    -mindepth 1 -maxdepth 2 -type d 2>/dev/null | fzf)
fi

[[ -z $selected ]] && exit 0

selected_name=$(basename "$selected" | tr . _)
tmux_running=$(pgrep tmux)

# Not in tmux, no server running -> start one with this session
if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
  tmux new-session -s "$selected_name" -c "$selected"
  exit 0
fi

# Session doesn't exist yet -> create it detached
if ! tmux has-session -t="$selected_name" 2>/dev/null; then
  tmux new-session -ds "$selected_name" -c "$selected"
fi

# Switch to it (or attach if outside tmux)
if [[ -z $TMUX ]]; then
  tmux attach -t "$selected_name"
else
  tmux switch-client -t "$selected_name"
fi
